{
  "name": "game-news-extension",
  "private": true,
  "version": "0.1.0",
  "description": "Game News browser extension — Steam integration (web + desktop via Millennium/Extendium)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
